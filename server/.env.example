# Copy this file to server/.env and fill in your values.

# Neon Postgres connection string (Dashboard -> your project -> Connection string).
# Looks like: postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Secret used to sign auth tokens. Use any long random string (32+ chars).
JWT_SECRET=

# Google OAuth 2.0 Client ID (ends with .apps.googleusercontent.com).
# Same value as VITE_GOOGLE_CLIENT_ID in the root .env. Leave empty to disable Google sign-in.
GOOGLE_CLIENT_ID=

# Google Gemini API key (https://aistudio.google.com/app/apikey).
# Leave empty to use the built-in rule-based classifier + exact-match dedup.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004

# Seed accounts for `npm run seed`. SEED_ADMIN_* are REQUIRED (no defaults).
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_STUDENT_EMAIL=
SEED_STUDENT_PASSWORD=

# Cloudinary — optional complaint media (photo/video). All three required to
# enable uploads (https://cloudinary.com → Dashboard → Product Environment Credentials).
# Leave empty to disable the media step entirely (the API returns 503 for uploads).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Port the API listens on (the Vite dev server proxies /api here).
PORT=4000

# Production frontend origin for CORS (e.g. https://your-app.vercel.app).
FRONTEND_ORIGIN=
