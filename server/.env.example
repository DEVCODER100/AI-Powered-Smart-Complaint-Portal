# Copy this file to server/.env and fill in your values.

# Neon Postgres connection string (Dashboard -> your project -> Connection string).
# Looks like: postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Secret used to sign auth tokens. Use any long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Port the API listens on (the Vite dev server proxies /api here).
PORT=4000
